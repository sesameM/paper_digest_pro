# ================================================================
# paper-distill-pro  —  environment variables template
# Copy to .env and fill in your values.
# ================================================================

# ── General ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
HTTP_TIMEOUT=15.0
USER_AGENT=paper-distill-pro/0.1.0 (mailto:you@example.com)

# ── Academic API keys (all optional — free sources work without) ──
# Semantic Scholar  https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# CORE  https://core.ac.uk/services/api  (free, improves full-text)
CORE_API_KEY=

# Unpaywall  (email required, no key needed)
UNPAYWALL_EMAIL=you@example.com

# PubMed  https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=

# IEEE Xplore  https://developer.ieee.org/  (free registration)
IEEE_API_KEY=

# SSRN  (optional; public search works without a key)
SSRN_API_KEY=

# ── Zotero sync ───────────────────────────────────────────────────
# API key: https://www.zotero.org/settings/keys
ZOTERO_API_KEY=
ZOTERO_USER_ID=         # numeric ID from zotero.org/settings/keys
ZOTERO_GROUP_ID=        # optional — sync to group library

# ── Mendeley sync (OAuth 2.0) ─────────────────────────────────────
# Register app: https://dev.mendeley.com/
MENDELEY_CLIENT_ID=
MENDELEY_CLIENT_SECRET=
# After first OAuth flow, store the token here for subsequent runs:
MENDELEY_ACCESS_TOKEN=
MENDELEY_REFRESH_TOKEN=

# ── Notion sync ───────────────────────────────────────────────────
# Integration: https://www.notion.so/my-integrations
NOTION_TOKEN=
NOTION_DATABASE_ID=     # from the database URL

# ── Sub-agent (LLM for enhanced PDF parsing) ───────────────────────
# API key from Anthropic / OpenAI-compatible provider
SUB_AGENT_API_KEY=
# Base URL (default: Anthropic); change for OpenAI / Groq / local servers
SUB_AGENT_BASE_URL=https://api.anthropic.com/v1
# Model name (e.g. claude-3-5-sonnet-20241022, gpt-4o, etc.)
SUB_AGENT_MODEL=claude-3-5-sonnet-20241022
SUB_AGENT_MAX_TOKENS=4096

# ── Obsidian sync (local filesystem, no API key needed) ───────────
# Path to your Obsidian vault folder
OBSIDIAN_VAULT_PATH=~/Obsidian/Vault

# ── Push channels ─────────────────────────────────────────────────
# Comma-separated: slack, telegram, email, wecom, feishu
PUSH_CHANNELS=slack

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=XXX

# Feishu (飞书) group bot webhook
# Create bot: 飞书群 → 设置 → 群机器人 → 添加机器人 → 类型选"自定义机器人"
# Webhook URL 格式: https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx

# SMTP (Gmail example — use App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# ── Digest / scheduler settings ───────────────────────────────────
PUSH_KEYWORDS=large language models,retrieval augmented generation
PUSH_SINCE_DAYS=7
PUSH_MAX_PAPERS_PER_KEYWORD=5
PUSH_DIGEST_TITLE=Scholar Daily Digest
